# Ariadne — example environment configuration.
#
# Copy this to `.env` (gitignored) and uncomment exactly ONE profile below,
# filling in your own credentials. Never commit real keys.
#
#   cp .env.example .env
#   # edit .env
#   set -a; source .env; set +a
#
# All LLM configuration flows through ariadne.llm.build_model(), which reads
# these three variables. Explicit function args always win over env vars.

# --- Optional: Logfire tracing (see ariadne.llm.configure_observability) ---
# Opt-in only. Leave both unset for a completely offline, untraced run.
# Set either one to turn tracing on:
#   ARIADNE_TRACE=1          # trace with local/default Logfire config, no token needed
#   LOGFIRE_TOKEN=...        # send traces to your Logfire project
#
# LOGFIRE_TOKEN=
# ARIADNE_TRACE=1

# ---------------------------------------------------------------------------
# Profile 1 — Anthropic native (default; no base URL)
# ---------------------------------------------------------------------------
# With ARIADNE_LLM_BASE_URL unset, build_model() returns the model string
# unchanged and pydantic-ai resolves it natively via its own Anthropic
# provider. In this mode the model string KEEPS its "anthropic:" prefix, and
# auth comes from the standard ANTHROPIC_API_KEY variable (NOT
# ARIADNE_LLM_API_KEY).
#
# ARIADNE_LLM_MODEL=anthropic:claude-opus-4-8
# ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# ---------------------------------------------------------------------------
# Profile 2 — Ollama, running locally
# ---------------------------------------------------------------------------
# With ARIADNE_LLM_BASE_URL set, build_model() returns an OpenAIChatModel, so
# the model name must be UNPREFIXED (no "anthropic:", no provider prefix) —
# build_model() raises ValueError if ARIADNE_LLM_MODEL is missing in this
# mode. Ollama ignores the API key but the OpenAI-compatible client still
# requires some non-empty string.
#
# ARIADNE_LLM_MODEL=llama3
# ARIADNE_LLM_BASE_URL=http://localhost:11434/v1
# ARIADNE_LLM_API_KEY=ollama-local-no-key-needed

# ---------------------------------------------------------------------------
# Profile 3 — OpenRouter
# ---------------------------------------------------------------------------
# Same rule as Ollama: base URL set -> unprefixed model name required.
# Use whatever model slug OpenRouter exposes for the model you want.
#
# ARIADNE_LLM_MODEL=anthropic/claude-opus-4.8
# ARIADNE_LLM_BASE_URL=https://openrouter.ai/api/v1
# ARIADNE_LLM_API_KEY=sk-or-v1-REPLACE_ME
